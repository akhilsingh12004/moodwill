# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/moodwill
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/moodwill

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Client ────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
